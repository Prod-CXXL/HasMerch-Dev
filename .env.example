# HasMerch Environment Variables
# Copy this file to .env and fill in your local values.
# NEVER commit .env to source control.
# In production, set these in Cloudflare Pages → Settings → Environment Variables.

# Database
DB_HOST=localhost
DB_NAME=hasmerch
DB_USER=root
DB_PASS=

# Stripe
STRIPE_PUBLISHABLE_KEY=pk_test_
STRIPE_SECRET_KEY=sk_test_
STRIPE_WEBHOOK_SECRET=whsec_

# Snipcart (per-store keys stored in branding DB record)
SNIPCART_KEY=

# App
APP_ENV=development
