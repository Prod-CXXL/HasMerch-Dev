# HasMerch — Environment Variables
#
# Copy this file to .env and fill in your local values.
# NEVER commit .env to source control.
# In production, set these in Cloudflare Pages → Settings → Environment Variables.
#
# See SECURITY.md and DEVELOPMENT.md for full guidance.

# ─── Database ───────────────────────────────────────────────
DB_HOST=localhost
DB_NAME=hasmerch
DB_USER=root
DB_PASS=

# ─── Stripe ─────────────────────────────────────────────────
# Publishable key — safe for client-side use
STRIPE_PUBLISHABLE_KEY=pk_test_

# Secret key — SERVER-SIDE ONLY, never expose in frontend code
STRIPE_SECRET_KEY=sk_test_

# Webhook signing secret — from Stripe Dashboard → Webhooks
STRIPE_WEBHOOK_SECRET=whsec_

# ─── Snipcart ───────────────────────────────────────────────
# Per-store keys are stored in the branding DB record.
# Platform-level default (optional):
SNIPCART_KEY=

# ─── App ────────────────────────────────────────────────────
# Set to 'production' or 'development'
APP_ENV=development
